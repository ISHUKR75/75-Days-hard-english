      "questions": [
        { "id": 1, "question": "Which is correct?", "options": ["There is many students.", "There are many students.", "There have many students.", "There be many students."], "answer": "There are many students.", "explanation": "Many students = plural, so use 'are'" },
        { "id": 2, "question": "Complete: ___ a meeting tomorrow.", "options": ["There is", "There are", "There will be", "There was"], "answer": "There will be", "explanation": "Tomorrow = future, so use 'will be'" },
        { "id": 3, "question": "Which is WRONG?", "options": ["There is a book.", "There are books.", "There is books.", "There was a problem."], "answer": "There is books.", "explanation": "Books = plural, must use 'are' not 'is'" },
        { "id": 4, "question": "___ no water in the tank.", "options": ["There is", "There are", "There were", "There will"], "answer": "There is", "explanation": "Water = uncountable, use 'is'" },
        { "id": 5, "question": "Past plural form:", "options": ["There is", "There are", "There was", "There were"], "answer": "There were", "explanation": "Past + plural = There were" },
        { "id": 6, "question": "Question form of 'There is a pen.':", "options": ["Is there a pen?", "Are there a pen?", "Does there a pen?", "Has there a pen?"], "answer": "Is there a pen?", "explanation": "Singular present question: Is there?" },
        { "id": 7, "question": "Present Perfect singular:", "options": ["There is been", "There has been", "There have been", "There was been"], "answer": "There has been", "explanation": "Present Perfect singular = There has been" },
        { "id": 8, "question": "Negative of 'There are students.':", "options": ["There isn't students.", "There aren't students.", "There not are students.", "There don't have students."], "answer": "There aren't students.", "explanation": "Plural negative = There aren't" },
        { "id": 9, "question": "___ a lot of traffic on Monday mornings.", "options": ["There are", "There is", "There were", "There will"], "answer": "There is", "explanation": "Traffic = uncountable, use 'is'" },
        { "id": 10, "question": "Which uses 'There were' correctly?", "options": ["There were a dog.", "There were five cats.", "There were much noise.", "There were a problem."], "answer": "There were five cats.", "explanation": "Five cats = plural past = There were" },
        { "id": 11, "question": "Future negative:", "options": ["There isn't be", "There won't be", "There weren't be", "There hasn't be"], "answer": "There won't be", "explanation": "Future negative = There won't be (will not be)" },
        { "id": 12, "question": "___ many changes in the system recently.", "options": ["There is", "There was", "There have been", "There will be"], "answer": "There have been", "explanation": "Recently + plural = There have been" },
        { "id": 13, "question": "Question for past plural:", "options": ["Is there?", "Are there?", "Was there?", "Were there?"], "answer": "Were there?", "explanation": "Past plural question = Were there?" },
        { "id": 14, "question": "___ any milk in the fridge? — No, ___ isn't.", "options": ["Is there / there", "Are there / there", "Was there / there", "Were there / there"], "answer": "Is there / there", "explanation": "Milk = uncountable singular = Is there / there isn't" },
        { "id": 15, "question": "Which is the CORRECT Present Perfect plural?", "options": ["There has been many problems.", "There have been many problems.", "There were been many problems.", "There are been many problems."], "answer": "There have been many problems.", "explanation": "Present Perfect plural = There have been" },
        { "id": 16, "question": "Choose the correct sentence:", "options": ["There is five people.", "There are five person.", "There are five people.", "There have five people."], "answer": "There are five people.", "explanation": "Five people = plural present = There are" },
        { "id": 17, "question": "'कल एक accident था।' in English:", "options": ["There is an accident yesterday.", "There was an accident yesterday.", "There were an accident yesterday.", "There had an accident yesterday."], "answer": "There was an accident yesterday.", "explanation": "Yesterday = past, singular = There was" },
        { "id": 18, "question": "Complete: ___ be a new mall here soon.", "options": ["There is", "There are", "There will", "There was"], "answer": "There will", "explanation": "Future = There will be (be is separate here)" },
        { "id": 19, "question": "Which is CORRECT?", "options": ["There have been a mistake.", "There has been a mistake.", "There was been a mistake.", "There is been a mistake."], "answer": "There has been a mistake.", "explanation": "A mistake = singular perfect = There has been" },
        { "id": 20, "question": "'क्या यहाँ कोई doctor है?' in English:", "options": ["Are there any doctor here?", "Is there a doctor here?", "Does there a doctor here?", "Have there a doctor here?"], "answer": "Is there a doctor here?", "explanation": "Singular present question = Is there?" }
      ]
